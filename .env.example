# Claude AI Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Storage mode: "local" (default) or "sharepoint"
STORAGE_MODE=local

# CORS — comma-separated origins allowed to call /api/* routes
# Add your Webflow domain and any custom domain
CORS_ORIGINS=http://localhost:5000,https://yoursite.webflow.io

# Local image storage (used when STORAGE_MODE=local)
IMAGE_FOLDER=./assets
SUPPORTED_FORMATS=.jpg,.jpeg,.png,.gif,.webp

# SharePoint / Microsoft Graph API
# Azure app registration requires Files.ReadWrite.All + Sites.ReadWrite.All (application permissions)
SHAREPOINT_TENANT_ID=your_tenant_id_here
SHAREPOINT_CLIENT_ID=your_client_id_here
SHAREPOINT_CLIENT_SECRET=your_client_secret_here
SHAREPOINT_DRIVE_ID=your_drive_id_here
SHAREPOINT_SITE_ID=your_site_id_here
SHAREPOINT_LIST_NAME=Assets
SHAREPOINT_IMAGE_FOLDER=Images

# Stock Photo Search
# Pexels — get your API key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Shutterstock — create an app at https://www.shutterstock.com/account/developers/apps
SHUTTERSTOCK_CLIENT_ID=your_shutterstock_client_id_here
SHUTTERSTOCK_CLIENT_SECRET=your_shutterstock_client_secret_here

# Unsplash — register at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pixabay — get your API key at https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here

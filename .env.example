# Airtable Configuration
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_base_id_here
AIRTABLE_TABLE_NAME=Assets

# Claude AI Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Image Paths
IMAGE_FOLDER=./assets
SUPPORTED_FORMATS=.jpg,.jpeg,.png,.gif,.webp

# Stock Photo Search
# Pexels — get your API key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Shutterstock — create an app at https://www.shutterstock.com/account/developers/apps
SHUTTERSTOCK_CLIENT_ID=your_shutterstock_client_id_here
SHUTTERSTOCK_CLIENT_SECRET=your_shutterstock_client_secret_here

# Unsplash — register at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
